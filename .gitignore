# All folders starting with _ are local.
_*/
# But keep the Sphinx extensions directory.
!docs/_ext/

# Compiled python files.
*.py[cod]

# Visual Studio files.
/.vs
**/.vscode/ipch

# macOS files.
.DS_Store

# Generated license file.
PACKAGE-DEPS.yaml

# packman .user config
*.packman.xml.user

# vscode settings are copied and filled in from 'settings.json.template'
.vscode/settings.json

# PyCharm files.
/.idea/

# Linux in docker build $HOME dirs
/.nvidia-omniverse
/.local
/.cache

# Omniverse EULA breadcrumb
/.omniverse_eula_accepted.txt

# Crash dumps and logs
**/*.dmp.zip.toml
**/*.dmp.zip
**/crash*.txt

/CMakeSettings.json

# Don't commit uv.lock files, pin explicit versions where required instead.
uv.lock
**/uv.lock
