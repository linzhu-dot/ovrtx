#usda 1.0
(
    # Sublayer of ovrtx-test-base.usda that animates /World/logo's translate
    # attribute left-to-right along X across time codes 0..60.  Used by
    # update_from_usd_time_async tests to verify that time-sampled attributes
    # are evaluated at the requested stage time.
    defaultPrim = "World"
    endTimeCode = 60
    startTimeCode = 0
    subLayers = [
        @./ovrtx-test-base.usda@
    ]
    timeCodesPerSecond = 60
    upAxis = "Y"
)

over "World"
{
    over "logo"
    {
        double3 xformOp:translate.timeSamples = {
            0: (-100, 3.4279940405311304, 0),
            60: (100, 3.4279940405311304, 0),
        }
    }
}
