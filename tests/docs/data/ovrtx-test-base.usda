    defaultPrim = "World"
    endTimeCode = 100
    metersPerUnit = 0.01
    startTimeCode = 0
    subLayers = [
        @./ovrtx-test-base-light.usda@,
        @./ovrtx-test-base-camera.usda@,
        @./ovrtx-test-base-materials.usda@,
        @./ovrtx-test-base-geometry.usda@
    ]
    timeCodesPerSecond = 60
    upAxis = "Y"
)

def Scope "Render"
{
    def RenderProduct "Camera" (prepend apiSchemas = ["OmniRtxDebugSettingsAPI_1"]) {
        rel camera = </World/Camera>
        int2 resolution = (512, 512)
        rel orderedVars = <LdrColor>

        def RenderVar "LdrColor" {
            string sourceName = "LdrColor"
        }
    }
}
