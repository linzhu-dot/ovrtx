#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
)

over "World" (
    prepend apiSchemas = ["OmniProjectorAPI"]
)
{
    double3 omni:projector:scale = (0.005, 0.005, 0.005)
    token omni:projector:space = "world"
    double3 omni:projector:uv:scale = (1, 1, 1)

    def Scope "Looks"
    {
        def Material "srf_grid"
        {
            token outputs:mdl:displacement.connect = </World/Looks/srf_grid/Shader.outputs:out>
            token outputs:mdl:surface.connect = </World/Looks/srf_grid/Shader.outputs:out>
            token outputs:mdl:volume.connect = </World/Looks/srf_grid/Shader.outputs:out>

            def Shader "Shader"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                asset inputs:diffuse_texture = @./lookdev_grid_10k.png@ (
                    colorSpace = "auto"
                )
                token outputs:out (
                    renderType = "material"
                )
            }
        }

        def Material "srf_green_plastic"
        {
            token outputs:mdl:displacement.connect = </World/Looks/srf_green_plastic/Shader.outputs:out>
            token outputs:mdl:surface.connect = </World/Looks/srf_green_plastic/Shader.outputs:out>
            token outputs:mdl:volume.connect = </World/Looks/srf_green_plastic/Shader.outputs:out>

            def Shader "Shader"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                color3f inputs:diffuse_color_constant = (0.181, 0.485, 0.0003)
                float inputs:reflection_roughness_constant = 0
                token outputs:out (
                    renderType = "material"
                )
            }
        }

        def Material "srf_grey"
        {
            token outputs:mdl:displacement.connect = </World/Looks/srf_grey/Shader.outputs:out>
            token outputs:mdl:surface.connect = </World/Looks/srf_grey/Shader.outputs:out>
            token outputs:mdl:volume.connect = </World/Looks/srf_grey/Shader.outputs:out>

            def Shader "Shader"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniPBR.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                color3f inputs:diffuse_color_constant = (0.18, 0.18, 0.18)
                float inputs:specular_level = 0.3
                token outputs:out (
                    renderType = "material"
                )
            }
        }

        def Material "srf_glass"
        {
            token outputs:mdl:displacement.connect = </World/Looks/srf_glass/Shader.outputs:out>
            token outputs:mdl:surface.connect = </World/Looks/srf_glass/Shader.outputs:out>
            token outputs:mdl:volume.connect = </World/Looks/srf_glass/Shader.outputs:out>

            def Shader "Shader"
            {
                uniform token info:implementationSource = "sourceAsset"
                uniform asset info:mdl:sourceAsset = @OmniGlass.mdl@
                uniform token info:mdl:sourceAsset:subIdentifier = "OmniGlass"
                token outputs:out (
                    renderType = "material"
                )
            }
        }
    }
}
